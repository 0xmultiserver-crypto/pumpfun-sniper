{
  "name": "pumpfun-sniper",
  "version": "0.1.0",
  "description": "Solana Pump.fun selective sniper infrastructure",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "backtest": "tsx src/backtest/cli.ts",
    "precommit": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "@moonit/sdk": "^1.5.0",
    "@pump-fun/pump-sdk": "^1.36.0",
    "@solana/spl-token": "^0.4.12",
    "@solana/web3.js": "^1.98.0",
    "@types/bn.js": "^5.2.0",
    "@wen-moon-ser/moonshot-sdk": "^4.3.0",
    "bn.js": "^5.2.3",
    "dotenv": "^16.4.7",
    "ioredis": "^5.4.2",
    "moonshot-sdk": "^0.0.1-alpha.4",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "eslint": "^9.15.0",
    "prettier": "^3.4.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.16.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "solana",
    "pumpfun",
    "sniper",
    "trading"
  ],
  "license": "UNLICENSED"
}
