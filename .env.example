# ============================================================
# PUMPFUN SNIPER — ENVIRONMENT VARIABLES
# ============================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ---------------------------------------------------------------------------
# RPC ENDPOINTS (priority order: Helius > PublicNode > Alchemy)
# ---------------------------------------------------------------------------

# PRIMARY: Helius (required — paid, fastest, priority fee API)
HELIUS_API_KEY=your_helius_api_key_here

# FALLBACK #1: PublicNode (free, no auth)
PUBLICNODE_RPC_URL=https://solana-rpc.publicnode.com

# FALLBACK #2: Alchemy (optional — paid)
ALCHEMY_API_KEY=

# WebSocket (Helius WSS for real-time subscriptions)
SOLANA_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ---------------------------------------------------------------------------
# STORAGE
# ---------------------------------------------------------------------------

DATABASE_URL=postgresql://user:password@localhost:5432/pumpfun
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# WALLET
# ---------------------------------------------------------------------------

# Base64-encoded 64-byte secret key
WALLET_SECRET_KEY=

# ---------------------------------------------------------------------------
# OPTIONAL
# ---------------------------------------------------------------------------

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Node environment
NODE_ENV=production
